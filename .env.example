# =====================================================
# VARIABLES DE ENTORNO - TradeBot Pro
# =====================================================
# Copia este archivo como .env y rellena los valores
# NUNCA subas el .env real a GitHub

# URL del backend en Railway (se obtiene tras el deploy)
# Ejemplo: https://tradebotpro-production.up.railway.app
VITE_GATEWAY_URL=

# Credenciales IQ Option (solo para Railway, no para el frontend)
IQ_OPTION_EMAIL=
IQ_OPTION_PASSWORD=
IQ_OPTION_MODE=PRACTICE
